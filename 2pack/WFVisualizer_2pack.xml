<?xml version="1.0" encoding="UTF-8"?>
<!--
  2Pack untuk mendaftarkan WFVisualizerForm ke Application Dictionary.

  File ini di-zip oleh proses build (lihat pom.xml, maven-antrun-plugin) menjadi
  META-INF/2Pack_org.nsoft.wf.visualizer_1.0.0.zip di dalam bundle jar, lalu
  di-install otomatis oleh MyActivator (extends
  org.adempiere.plugin.utils.Incremental2PackActivator) saat bundle pertama
  kali aktif.
-->
<idempiere_2pack version="1.0">

  <!-- ═══════════════════════════════════════════════════════════════════════
       AD_Form — registrasi form class
       ═══════════════════════════════════════════════════════════════════════ -->
  <adForm
    id="org.nsoft.wf.visualizer.WFVisualizerForm"
    AD_Form_UU="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    Name="WF Visualizer"
    Description="Visualisasi Workflow: Flow Diagram, Comparative Graph, Timeline, dan Statistik"
    Classname="org.nsoft.wf.visualizer.WFVisualizerForm"
    EntityType="U"
    IsActive="Y"
    AD_Client_ID="0"
    AD_Org_ID="0"
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       AD_Menu — entry menu di bawah Workflow > Reports
       ═══════════════════════════════════════════════════════════════════════ -->
  <adMenu
    id="org.nsoft.wf.visualizer.menu"
    AD_Menu_UU="b2c3d4e5-f6a7-8901-bcde-f12345678901"
    Name="Workflow Visualizer"
    Description="Visualisasi Workflow iDempiere"
    IsActive="Y"
    IsSummary="N"
    IsSOTrx="N"
    Action="X"
    AD_Form_ID="org.nsoft.wf.visualizer.WFVisualizerForm"
    EntityType="U"
    AD_Client_ID="0"
    AD_Org_ID="0"
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       AD_TreeNodeMM — posisi menu (parent = Workflow menu group)
       ═══════════════════════════════════════════════════════════════════════ -->
  <adTreeNodeMM
    id="org.nsoft.wf.visualizer.treenode"
    AD_Menu_ID="org.nsoft.wf.visualizer.menu"
    SeqNo="100"
    EntityType="U"
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       AD_Message — pesan i18n untuk UI labels
       ═══════════════════════════════════════════════════════════════════════ -->
  <adMessage
    id="WFVis_SelectWorkflow"
    AD_Message_UU="c3d4e5f6-a7b8-9012-cdef-123456789012"
    Value="WFVis_SelectWorkflow"
    MsgText="Pilih Workflow"
    MsgType="I"
    EntityType="U"
  />
  <adMessage
    id="WFVis_SelectWorkflow_En"
    AD_Message_UU="d4e5f6a7-b8c9-0123-def0-234567890123"
    Value="WFVis_SelectWorkflow"
    MsgText="Select Workflow"
    MsgType="I"
    EntityType="U"
    AD_Language="en_US"
  />

  <adMessage
    id="WFVis_Visualize"
    AD_Message_UU="e5f6a7b8-c9d0-1234-ef01-345678901234"
    Value="WFVis_Visualize"
    MsgText="Visualisasi"
    MsgType="I"
    EntityType="U"
  />

  <adMessage
    id="WFVis_StatusLoading"
    AD_Message_UU="f6a7b8c9-d0e1-2345-f012-456789012345"
    Value="WFVis_StatusLoading"
    MsgText="Memuat data..."
    MsgType="I"
    EntityType="U"
  />

  <adMessage
    id="WFVis_HighlightBottleneck"
    AD_Message_UU="a7b8c9d0-e1f2-3456-0123-567890123456"
    Value="WFVis_HighlightBottleneck"
    MsgText="Highlight Bottleneck"
    MsgType="I"
    EntityType="U"
  />

</idempiere_2pack>
